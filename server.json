{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "com.getspm/spm",
  "title": "SPM - Structured Project Memory",
  "description": "Durable, shareable and governed project memory with smart triage and explicit project composition.",
  "websiteUrl": "https://getspm.com",
  "repository": {
    "url": "https://github.com/getspm/spm-agent-connectors",
    "source": "github"
  },
  "version": "0.2.3",
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://getspm.com/v1/mcp",
      "headers": [
        {
          "name": "Authorization",
          "description": "Bearer token authorized for one project, a selected project set or the projects available to an organization user.",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ],
  "_meta": {
    "io.modelcontextprotocol.registry/publisher-provided": {
      "homepage": "https://getspm.com",
      "agentIntegrationGuide": "https://getspm.com/agents",
      "security": "https://getspm.com/security",
      "demoVideo": "https://getspm.com/sales/spm-current-scoped-trusted-agent-memory.mp4",
      "directoryListing": "https://github.com/getspm/spm-agent-connectors/blob/main/docs/directory-listing-pack.md",
      "excludedConnectorSurfaces": [
        "billing",
        "checkout",
        "invoice_payment",
        "customer_portal",
        "destructive_tenant_administration",
        "raw_secret_return",
        "cross_project_composition_without_explicit_user_request"
      ],
      "capabilities": [
        "smart_project_memory",
        "temporal_memory",
        "context_graphs",
        "scoped_context_packs",
        "mcp_cli_api_injection",
        "access_control",
        "provenance_hash_verification",
        "agent_policy_preflight",
        "automatic_project_resolution",
        "explicit_multi_project_composition",
        "federated_project_mounts",
        "agent_lifecycle_triage",
        "reviewable_project_memory_bootstrap"
      ]
    }
  }
}
