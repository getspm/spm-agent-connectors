{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.getspm/spm",
  "title": "SPM - Structured Project Memory",
  "description": "Structured project memory for AI agents, delivered through a project-scoped remote MCP connector.",
  "websiteUrl": "https://getspm.com",
  "repository": {
    "url": "https://github.com/getspm/spm-agent-connectors",
    "source": "github"
  },
  "version": "0.1.1",
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://getspm.com/v1/mcp",
      "headers": [
        {
          "name": "Authorization",
          "description": "Bearer token for a project-scoped SPM MCP connector token.",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ],
  "_meta": {
    "io.modelcontextprotocol.registry/publisher-provided": {
      "homepage": "https://getspm.com",
      "agentIntegrationGuide": "https://getspm.com/agents",
      "security": "https://getspm.com/security",
      "demoVideo": "https://getspm.com/sales/spm-current-scoped-trusted-agent-memory.mp4",
      "directoryListing": "https://github.com/getspm/spm-agent-connectors/blob/main/docs/directory-listing-pack.md",
      "excludedConnectorSurfaces": [
        "billing",
        "checkout",
        "invoice_payment",
        "customer_portal",
        "destructive_tenant_administration",
        "raw_secret_return",
        "cross_project_access_without_explicit_project_token"
      ],
      "capabilities": [
        "smart_project_memory",
        "temporal_memory",
        "context_graphs",
        "scoped_context_packs",
        "mcp_cli_api_injection",
        "access_control",
        "provenance_hash_verification",
        "agent_policy_preflight"
      ]
    }
  }
}
